# Mock Mode — when false, hooks call the backend (recommended for chats / payments).
# Backend dev uses MOCK_PAYMENTS (see zexy_api .env.example) so intents + verify succeed without Razorpay.
NEXT_PUBLIC_USE_MOCK=true

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3001

# Razorpay (for payment integration)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
